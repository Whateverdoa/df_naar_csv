# FastAPI Configuration
DEBUG=true
PROJECT_NAME="DF naar CSV API"
VERSION="1.0.0"

# File Upload Settings
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR="uploads"

# Processing Defaults
DEFAULT_MES=4
DEFAULT_VDP_AANTAL=1
DEFAULT_EXTRA_ETIKETTEN=10
DEFAULT_WIKKEL=1
DEFAULT_KERN=76
DEFAULT_FORMAAT_HOOGTE=80
DEFAULT_FORMAAT_BREEDTE=80

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8080,http://localhost:4200"
